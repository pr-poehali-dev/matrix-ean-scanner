      "expectedStatus": 400,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing codes returns 400",
      "method": "POST",
      "path": "/",
      "body": {"server_ip": "192.168.1.1", "codes": []},
      "expectedStatus": 400,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Connection check - missing ip",
      "method": "GET",
      "path": "/?server_ip=",
      "expectedStatus": 400,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
